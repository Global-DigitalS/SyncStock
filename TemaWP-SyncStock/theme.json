					"name": "Transparente"
				}
			],
			"gradients": [
				{
					"slug": "brand-gradient",
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--brand-600) 0%, var(--wp--preset--color--violet-700) 100%)",
					"name": "Brand Gradient"
				},
				{
					"slug": "brand-light",
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--brand-50) 0%, var(--wp--preset--color--white) 100%)",
					"name": "Brand Light"
				},
				{
					"slug": "hero-gradient",
					"gradient": "linear-gradient(to bottom, var(--wp--preset--color--slate-50) 0%, var(--wp--preset--color--white) 100%)",
					"name": "Hero Gradient"
				},
				{
					"slug": "cta-gradient",
					"gradient": "linear-gradient(135deg, var(--wp--preset--color--brand-600) 0%, var(--wp--preset--color--violet-700) 50%, var(--wp--preset--color--brand-800) 100%)",
					"name": "CTA Gradient"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
					"slug": "body",
					"name": "Inter (Body)",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "300 900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"]
						}
					]
				},
				{
					"fontFamily": "'Manrope', 'Inter', sans-serif",
					"slug": "heading",
					"name": "Manrope (Heading)",
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontWeight": "400 800",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"]
						}
					]
				},
				{
					"fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
					"slug": "mono",
					"name": "JetBrains Mono"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.75rem",
					"name": "Extra Small"
				},
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.125rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "1.25rem",
					"name": "Extra Large"
				},
				{
					"slug": "2x-large",
					"size": "1.5rem",
					"name": "2X Large"
				},
				{
					"slug": "3x-large",
					"size": "clamp(1.75rem, 3vw, 2.25rem)",
					"name": "3X Large"
				},
				{
					"slug": "4x-large",
					"size": "clamp(2rem, 4vw, 3rem)",
					"name": "4X Large"
				},
				{
					"slug": "5x-large",
					"size": "clamp(2.5rem, 5vw, 3.75rem)",
					"name": "5X Large"
				},
				{
					"slug": "hero",
					"size": "clamp(2.75rem, 6vw, 4.5rem)",
					"name": "Hero"
				}
			]
		},
		"spacing": {
			"units": ["px", "rem", "em", "%", "vw", "vh"],
			"spacingSizes": [
				{ "slug": "10", "size": "0.25rem", "name": "1" },
				{ "slug": "20", "size": "0.5rem", "name": "2" },
				{ "slug": "30", "size": "0.75rem", "name": "3" },
				{ "slug": "40", "size": "1rem", "name": "4" },
				{ "slug": "50", "size": "1.5rem", "name": "5" },
				{ "slug": "60", "size": "2rem", "name": "6" },
				{ "slug": "70", "size": "3rem", "name": "7" },
				{ "slug": "80", "size": "4rem", "name": "8" },
				{ "slug": "90", "size": "6rem", "name": "9" },
				{ "slug": "100", "size": "8rem", "name": "10" }
			]
		},
		"layout": {
			"contentSize": "768px",
			"wideSize": "1200px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"custom": {
			"borderRadius": {
				"sm": "0.375rem",
				"md": "0.5rem",
				"lg": "0.75rem",
				"xl": "1rem",
				"2xl": "1.5rem",
				"full": "9999px"
			},
			"shadow": {
				"sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
				"md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
				"lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
				"xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
				"2xl": "0 25px 50px -12px rgba(0, 0, 0, 0.25)"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--slate-800)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--50)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--50)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var(--wp--preset--color--slate-900)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--hero)",
					"fontWeight": "800"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--5x-large)",
					"fontWeight": "700"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3x-large)",
					"fontWeight": "600"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2x-large)",
					"fontWeight": "600"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--brand-600)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--brand-700)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--brand-600)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": {
					"radius": "0.5rem"
				},
				"typography": {
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--medium)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--brand-700)"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "700"
				},
				"color": {
					"text": "var(--wp--preset--color--brand-600)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--brand-500)",
						"width": "4px"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Cabecera",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Pie de página",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-home",
			"title": "Página de Inicio",
			"postTypes": ["page"]
		},
		{
			"name": "page-features",
			"title": "Características",
			"postTypes": ["page"]
		},
		{
			"name": "page-pricing",
			"title": "Precios",
			"postTypes": ["page"]
		},
		{
			"name": "page-about",
			"title": "Nosotros",
			"postTypes": ["page"]
		},
		{
			"name": "page-contact",
			"title": "Contacto",
			"postTypes": ["page"]
		},
		{
			"name": "page-blog",
			"title": "Blog",
			"postTypes": ["page"]
		},
		{
			"name": "page-privacy",
			"title": "Privacidad",
			"postTypes": ["page"]
		},
		{
			"name": "page-terms",
			"title": "Términos y Condiciones",
			"postTypes": ["page"]
		},
		{
			"name": "blank",
			"title": "En blanco",
			"postTypes": ["page", "post"]
		}
	]
}
