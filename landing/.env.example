# Landing Page Environment Variables
# Copy this file to .env.local and configure with real values

# ==================== API CONFIGURATION ====================
# Base URL of the SyncStock backend API
# For development: http://localhost:8000/api/v1
# For production: https://api.syncstock.com/api/v1
REACT_APP_API_URL=http://localhost:8000/api/v1

# Environment (development | production)
REACT_APP_ENV=development

# ==================== OPTIONAL: ANALYTICS ====================
# PostHog key for analytics tracking (optional)
# REACT_APP_POSTHOG_KEY=phc_your_key_here
