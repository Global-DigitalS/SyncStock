# Landing Page Environment Variables
# Copiar este archivo a .env.local y configurar con valores reales

# Base URL de la API del backend SyncStock
# Ejemplo desarrollo: http://localhost:8000/api/v1
# Ejemplo producción: https://api.syncstock.com/api/v1
REACT_APP_API_URL=http://localhost:8000/api/v1

# Entorno (development | production)
REACT_APP_ENV=development
